{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/strip-redundant-git-C.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/simplify-git-push.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/warn-no-verify-push.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/ban-gh-api-comments.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-delete-branch-in-worktree.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/warn-amend-pushed-commits.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-blanket-git-add.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-commit-on-main.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-merge-on-red-ci.sh", "timeout": 30 },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/warn-on-pr-merge.sh" }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-edits-on-main-or-root.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/remind-ci-after-push.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/post-merge-watch-deploy.sh", "timeout": 10 }
        ]
      }
    ]
  }
}
